{% extends "base.njk" %}

{% block head %}
<style>
/* ── Grid layouts ──────────────────────────────────────────── */
.member-grid       { display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem; margin-top:1.75rem; }
.member-grid--wide { grid-template-columns:repeat(2,1fr); }
@media (max-width:900px) { .member-grid { grid-template-columns:repeat(2,1fr); } .member-grid--wide { grid-template-columns:1fr; } }
@media (max-width:560px) { .member-grid { grid-template-columns:1fr; } }

/* ── Faculty card ──────────────────────────────────────────── */
.mc {
  background: var(--color-surface);
  border: 1px solid rgba(86,101,115,0.22);
  border-radius: 12px;
  padding: 1.25rem 1.375rem 1.125rem;
  display: flex;
  flex-direction: column;
  gap: 0;
  transition: border-color 0.22s, transform 0.22s, box-shadow 0.22s;
}
.mc:hover { border-color:rgba(233,79,55,0.42); transform:translateY(-3px); box-shadow:0 10px 36px rgba(0,0,0,0.28); }
.mc--coordinator { border-top: 3px solid var(--color-accent); }
.mc--collaborator { border-top: 3px solid var(--color-steel); }

/* Header row: avatar + meta */
.mc-header { display:flex; align-items:center; gap:0.875rem; margin-bottom:0.875rem; }
.mc-avatar {
  width:46px; height:46px; border-radius:50%; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  background:rgba(86,101,115,0.15); border:1.5px solid rgba(86,101,115,0.28);
  color:var(--color-muted);
}
.mc--coordinator .mc-avatar  { background:rgba(233,79,55,0.08); border-color:rgba(233,79,55,0.28); color:var(--color-accent); }
.mc--collaborator .mc-avatar { background:rgba(86,101,115,0.18); border-color:rgba(86,101,115,0.38); }
.mc-meta { flex:1; min-width:0; }
.mc-role {
  font-size:0.675rem; font-weight:700; text-transform:uppercase;
  letter-spacing:0.08em; line-height:1.2; margin-bottom:0.2rem;
  color:var(--color-accent);
}
.mc--collaborator .mc-role { color:var(--color-steel); }
.mc-name { font-family:var(--font-primary); font-size:0.9375rem; font-weight:700; color:var(--color-text); line-height:1.25; }

/* Tags */
.mc-tags { display:flex; flex-wrap:wrap; gap:0.3rem; margin-bottom:0.85rem; }
.mc-tag {
  font-size:0.695rem; color:var(--color-muted);
  background:rgba(86,101,115,0.12); border:1px solid rgba(86,101,115,0.22);
  border-radius:3px; padding:0.12rem 0.42rem; line-height:1.55; letter-spacing:0.01em;
}

/* Link buttons */
.mc-links { display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:auto; padding-top:0.75rem; border-top:1px solid rgba(86,101,115,0.12); }
.mc-link {
  display:inline-flex; align-items:center; gap:0.35rem;
  height:28px; padding:0 0.6rem;
  border:1px solid rgba(86,101,115,0.3); border-radius:5px;
  color:var(--color-muted); font-size:0.7375rem; font-weight:600;
  text-decoration:none; white-space:nowrap;
  transition:border-color 0.15s, color 0.15s, background 0.15s;
}
.mc-link:hover { border-color:rgba(233,79,55,0.5); color:var(--color-accent); background:rgba(233,79,55,0.06); }
.mc-link svg { flex-shrink:0; }

/* Student / undergrad card */
.mc-simple {
  background:var(--color-surface); border:1px solid rgba(86,101,115,0.18); border-radius:10px;
  padding:1rem 1.125rem; display:flex; flex-direction:column; gap:0.3rem;
  transition:border-color 0.2s;
}
.mc-simple:hover { border-color:rgba(233,79,55,0.32); }
.mc-simple-header { display:flex; align-items:center; gap:0.625rem; }
.mc-simple-avatar {
  width:32px; height:32px; border-radius:50%; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  background:rgba(86,101,115,0.12); border:1px solid rgba(86,101,115,0.22);
  color:rgba(136,146,176,0.6);
}
.mc-simple-name { font-family:var(--font-primary); font-size:0.9rem; font-weight:700; color:var(--color-text); }
.mc-since { font-size:0.775rem; color:rgba(136,146,176,0.5); }
.mc-simple-links { display:flex; gap:0.4rem; margin-top:0.5rem; }

/* Section chrome */
.section-divider { border:none; border-top:1px solid rgba(86,101,115,0.18); margin:3.5rem 0 0; }
.group-heading   { font-family:var(--font-primary); font-size:1.5rem; font-weight:800; color:var(--color-text); margin:2.5rem 0 0.25rem; }
.group-sub       { font-size:0.9375rem; color:var(--color-muted); margin-bottom:0.25rem; }
</style>
{% endblock %}

{% block content %}

{# ── Convenience aliases ── #}
{% set i18n = data.team_i18n %}
{% set tags = data.team_tags %}
{% set team = data.team %}

{# ── SVG snippets ── #}
{% set avatarSVG %}
<svg width="22" height="22" viewBox="0 0 22 22" fill="currentColor" aria-hidden="true">
  <circle cx="11" cy="8" r="4.5"/>
  <path d="M2 20c0-4.97 4.03-9 9-9s9 4.03 9 9" fill-rule="evenodd"/>
</svg>
{% endset %}

{% set avatarSVGSm %}
<svg width="15" height="15" viewBox="0 0 22 22" fill="currentColor" aria-hidden="true">
  <circle cx="11" cy="8" r="4.5"/>
  <path d="M2 20c0-4.97 4.03-9 9-9s9 4.03 9 9" fill-rule="evenodd"/>
</svg>
{% endset %}

{% set lattesIconSVG %}
<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
  <path d="M2 2h8v8M10 2 2 10"/>
</svg>
{% endset %}

{% set emailIconSVG %}
<svg width="13" height="12" viewBox="0 0 14 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
  <rect x="1" y="1" width="12" height="10" rx="1.5"/>
  <path d="M1 3l6 4.5L13 3"/>
</svg>
{% endset %}

{# ── Macros ── #}
{% macro renderFacultyLinks(links) %}
  {% if links %}
  <div class="mc-links">
    {% for l in links %}
      {% if l.key == 'profile' %}
        {# profile links removed per design spec #}
      {% elif l.href and 'mailto:' in l.href %}
      <a href="{{ l.href }}" class="mc-link" title="{{ l.text }}">
        {{ emailIconSVG | safe }} Email
      </a>
      {% elif l.text and 'Lattes' in l.text %}
      <a href="{{ l.href }}" target="_blank" rel="noopener" class="mc-link" title="Lattes CV">
        {{ lattesIconSVG | safe }} Lattes
      </a>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}
{% endmacro %}

{% macro renderStudentLinks(links) %}
  {% if links %}
  <div class="mc-simple-links">
    {% for l in links %}
      {% if l.text and 'Lattes' in l.text %}
      <a href="{{ l.href }}" target="_blank" rel="noopener" class="mc-link" title="Lattes CV">
        {{ lattesIconSVG | safe }} Lattes
      </a>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}
{% endmacro %}

{# ── Hero ── #}
<section style="padding-top:8rem;padding-bottom:2rem;">
  <div class="container">
    <span class="section-label">{{ page.page_label }}</span>
    <h1 class="d2c_title" style="margin-top:0.75rem;margin-bottom:0.75rem;">{{ page.page_title }}</h1>
    <p class="text-lavender" style="font-size:1rem;max-width:640px;line-height:1.75;">{{ page.page_sub }}</p>
  </div>
</section>

<section style="padding-top:0.5rem;">
  <div class="container">

    {# ── Coordenadores ── #}
    <hr class="section-divider" style="margin-top:0;" />
    <span class="section-label" style="margin-top:2.5rem;display:inline-block;">{{ i18n.groups.coordinators.label }}</span>
    <h2 class="group-heading">{{ i18n.groups.coordinators.title }}</h2>
    <p class="group-sub">{{ i18n.groups.coordinators.sub }}</p>
    <div class="member-grid member-grid--wide" data-aos="fade-up">
      {% for m in team.coordinators.members %}
      <div class="mc mc--coordinator">
        <div class="mc-header">
          <div class="mc-avatar">{{ avatarSVG | safe }}</div>
          <div class="mc-meta">
            <div class="mc-role">{{ i18n.roles[m.role_key] }}</div>
            <div class="mc-name">{{ i18n.name_prefixes[m.gender or 'm'] }} {{ m.name }}</div>
          </div>
        </div>
        {% if m.tags %}
        <div class="mc-tags">
          {% for tagId in m.tags %}<span class="mc-tag">{{ tags[tagId][lang] if tags[tagId] else tagId }}</span>{% endfor %}
        </div>
        {% endif %}
        {{ renderFacultyLinks(m.links) }}
      </div>
      {% endfor %}
    </div>

    {# ── Professores Pesquisadores ── #}
    <hr class="section-divider" />
    <span class="section-label" style="margin-top:2.5rem;display:inline-block;">{{ i18n.groups.professors.label }}</span>
    <h2 class="group-heading">{{ i18n.groups.professors.title }}</h2>
    <p class="group-sub">{{ i18n.groups.professors.sub }}</p>
    <div class="member-grid" data-aos="fade-up">
      {% for m in team.professors.members %}
      <div class="mc">
        <div class="mc-header">
          <div class="mc-avatar">{{ avatarSVG | safe }}</div>
          <div class="mc-meta">
            <div class="mc-role">{{ i18n.roles[m.role_key] }}</div>
            <div class="mc-name">{{ i18n.name_prefixes[m.gender or 'm'] }} {{ m.name }}</div>
          </div>
        </div>
        {% if m.tags %}
        <div class="mc-tags">
          {% for tagId in m.tags %}<span class="mc-tag">{{ tags[tagId][lang] if tags[tagId] else tagId }}</span>{% endfor %}
        </div>
        {% endif %}
        {{ renderFacultyLinks(m.links) }}
      </div>
      {% endfor %}
    </div>

    {# ── Colaboradores ── #}
    <hr class="section-divider" />
    <span class="section-label" style="margin-top:2.5rem;display:inline-block;">{{ i18n.groups.collaborators.label }}</span>
    <h2 class="group-heading">{{ i18n.groups.collaborators.title }}</h2>
    <div class="member-grid member-grid--wide" data-aos="fade-up">
      {% for m in team.collaborators.members %}
      <div class="mc mc--collaborator">
        <div class="mc-header">
          <div class="mc-avatar">{{ avatarSVG | safe }}</div>
          <div class="mc-meta">
            <div class="mc-role">{{ i18n.roles[m.role_key] }}</div>
            <div class="mc-name">{{ i18n.name_prefixes[m.gender or 'm'] }} {{ m.name }}</div>
          </div>
        </div>
        {% if m.tags %}
        <div class="mc-tags">
          {% for tagId in m.tags %}<span class="mc-tag">{{ tags[tagId][lang] if tags[tagId] else tagId }}</span>{% endfor %}
        </div>
        {% endif %}
        {{ renderFacultyLinks(m.links) }}
      </div>
      {% endfor %}
    </div>

    {# ── Doutorandos ── #}
    <hr class="section-divider" />
    <span class="section-label" style="margin-top:2.5rem;display:inline-block;">{{ i18n.groups.phd_students.label }}</span>
    <h2 class="group-heading">{{ i18n.groups.phd_students.title }}</h2>
    <p class="group-sub">{{ i18n.groups.phd_students.sub }}</p>
    <div class="member-grid" data-aos="fade-up">
      {% for m in team.phd_students.members %}
      <div class="mc-simple">
        <div class="mc-simple-header">
          <div class="mc-simple-avatar">{{ avatarSVGSm | safe }}</div>
          <div class="mc-simple-name">{{ m.name }}</div>
        </div>
        <div class="mc-since">{{ i18n.groups.phd_students.since_prefix }} {{ m.year }}</div>
        {{ renderStudentLinks(m.links) }}
      </div>
      {% endfor %}
    </div>

    {# ── Mestrandos ── #}
    <h2 class="group-heading" style="margin-top:2.5rem;">{{ i18n.groups.masters_students.title }}</h2>
    <div class="member-grid" data-aos="fade-up">
      {% for m in team.masters_students.members %}
      <div class="mc-simple">
        <div class="mc-simple-header">
          <div class="mc-simple-avatar">{{ avatarSVGSm | safe }}</div>
          <div class="mc-simple-name">{{ m.name }}</div>
        </div>
        <div class="mc-since">{{ i18n.groups.masters_students.since_prefix }} {{ m.year }}</div>
        {{ renderStudentLinks(m.links) }}
      </div>
      {% endfor %}
    </div>

    {# ── Graduandos ── #}
    <hr class="section-divider" />
    <span class="section-label" style="margin-top:2.5rem;display:inline-block;">{{ i18n.groups.undergrads.label }}</span>
    <h2 class="group-heading">{{ i18n.groups.undergrads.title }}</h2>
    <div class="member-grid" data-aos="fade-up">
      {% for m in team.undergrads.members %}
      <div class="mc-simple">
        <div class="mc-simple-header">
          <div class="mc-simple-avatar">{{ avatarSVGSm | safe }}</div>
          <div class="mc-simple-name">{{ m.name }}</div>
        </div>
        <div class="mc-since">{{ i18n.groups.undergrads.since_prefix }} {{ m.year }}</div>
        {{ renderStudentLinks(m.links) }}
      </div>
      {% endfor %}
    </div>

    {# ── Egressos ── #}
    <hr class="section-divider" />
    <span class="section-label" style="margin-top:2.5rem;display:inline-block;">{{ i18n.groups.alumni_grad.label }}</span>
    <h2 class="group-heading">{{ i18n.groups.alumni_grad.title }}</h2>
    <div class="alumni-list" data-aos="fade-up">
      {% for name in team.alumni_grad.members %}<span class="alumni-pill">{{ name }}</span>{% endfor %}
    </div>

    <h2 class="group-heading" style="margin-top:2.5rem;">{{ i18n.groups.alumni_undergrad.title }}</h2>
    <div class="alumni-list" data-aos="fade-up">
      {% for name in team.alumni_undergrad.members %}<span class="alumni-pill">{{ name }}</span>{% endfor %}
    </div>

    <div style="margin:4rem 0 2rem;text-align:center;">
      <p class="text-lavender" style="margin-bottom:1rem;">{{ page.join_text }}</p>
      <a href="{{ base_url }}/contato" class="btn-primary">{{ page.join_btn }}</a>
    </div>

  </div>
</section>

{% endblock %}
