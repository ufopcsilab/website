{% from "_macros.njk" import icon %}
<!DOCTYPE html>
<html lang="{{ lang_html }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ page.description }}" />
  <title>{{ page.title }}</title>
  <link rel="icon" href="/images/ufop-logo.png" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/dropdown.css" />
  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
  {% block head %}{% endblock %}
</head>
<body>

<!-- ─── Page Loader ─────────────────────────────────────── -->
<div id="page-loader">
  <div style="font-family:'Funnel Sans',sans-serif;font-size:1.75rem;font-weight:800;letter-spacing:-0.02em;">
    <span style="color:#E2E8F0;">CSI</span><span style="color:#E94F37;">Lab</span>
  </div>
</div>

<!-- ─── Animated Background ─────────────────────────────── -->
<div class="d2c_background" aria-hidden="true">
  <span></span><span></span><span></span><span></span>
  <span></span><span></span><span></span>
</div>

<!-- ─── Navigation ──────────────────────────────────────── -->
<nav id="navbar">
  <div class="container">
    <div class="nav-inner">
      <a href="{{ base_url }}" class="nav-logo">
        <img src="/images/logo-csilab.png" alt="CSI Lab" style="height:36px;"
             onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
        <span style="display:none;font-family:'Funnel Sans',sans-serif;font-size:1.25rem;font-weight:800;letter-spacing:-0.02em;">
          <span style="color:#E2E8F0;">CSI</span><span style="color:#E94F37;">Lab</span>
        </span>
      </a>
      <ul class="nav-links">
        <li><a href="{{ base_url }}">{{ data.nav.home }}</a></li>
        <li><a href="{{ base_url }}#pesquisa">{{ data.nav.research }}</a></li>
        <li><a href="{{ base_url }}/equipe"{% if currentPage == 'equipe' %} style="color:var(--color-accent);"{% endif %}>{{ data.nav.team }}</a></li>
        <li><a href="{{ base_url }}/publicacoes"{% if currentPage == 'publicacoes' %} style="color:var(--color-accent);"{% endif %}>{{ data.nav.publications }}</a></li>
        <li><a href="{{ base_url }}#consultorias">{{ data.nav.consulting }}</a></li>
        <li><a href="https://github.com/ufopcsilab" target="_blank" rel="noopener">{{ data.nav.github }}</a></li>
        <li><a href="{{ base_url }}#noticias">{{ data.nav.news }}</a></li>
      </ul>
      <div class="nav-actions">
        <a href="{{ base_url }}/contato" class="btn-contact"{% if currentPage == 'contato' %} style="color:var(--color-accent);"{% endif %}>{{ data.nav.contact_btn }}</a>
        <div class="lang-switcher">
          <a href="{{ lang_urls.pt }}" class="lang-btn{% if lang == 'pt' %} active{% endif %}">PT</a>
          <a href="{{ lang_urls.en }}" class="lang-btn{% if lang == 'en' %} active{% endif %}">EN</a>
          <a href="{{ lang_urls.es }}" class="lang-btn{% if lang == 'es' %} active{% endif %}">ES</a>
          <a href="{{ lang_urls.it }}" class="lang-btn{% if lang == 'it' %} active{% endif %}">IT</a>
        </div>
      </div>
      <div class="hamburger" id="hamburger" aria-label="{{ data.nav.open_menu }}">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>
</nav>

<div class="nav-overlay" id="nav-overlay"></div>
<div class="mobile-nav" id="mobile-nav">
  <span class="mobile-close" id="mobile-close">&#x2715;</span>
  <a href="{{ base_url }}">{{ data.nav.home }}</a>
  <a href="{{ base_url }}#pesquisa">{{ data.nav.research }}</a>
  <a href="{{ base_url }}/equipe">{{ data.nav.team }}</a>
  <a href="{{ base_url }}/publicacoes">{{ data.nav.publications }}</a>
  <a href="{{ base_url }}#consultorias">{{ data.nav.consulting }}</a>
  <a href="https://github.com/ufopcsilab" target="_blank">{{ data.nav.github }}</a>
  <a href="{{ base_url }}#noticias">{{ data.nav.news }}</a>
  <a href="{{ base_url }}/contato">{{ data.nav.contact_btn }}</a>
  <div class="lang-switcher lang-switcher--mobile">
    <a href="{{ lang_urls.pt }}" class="lang-btn{% if lang == 'pt' %} active{% endif %}">PT</a>
    <a href="{{ lang_urls.en }}" class="lang-btn{% if lang == 'en' %} active{% endif %}">EN</a>
    <a href="{{ lang_urls.es }}" class="lang-btn{% if lang == 'es' %} active{% endif %}">ES</a>
    <a href="{{ lang_urls.it }}" class="lang-btn{% if lang == 'it' %} active{% endif %}">IT</a>
  </div>
</div>

{% block content %}{% endblock %}

<!-- ─── Footer ────────────────────────────────────────────── -->
<footer>
  <div class="container">
    {% block footer_top %}
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/images/logo-csilab.png" alt="CSI Lab" style="height:48px;margin-bottom:1rem;"
             onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <div style="display:none;font-family:'Funnel Sans',sans-serif;font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:1rem;">
          <span style="color:#E2E8F0;">CSI</span><span style="color:#E94F37;">Lab</span>
        </div>
        <p>{{ data.footer.brand_text }}</p>
        <div style="margin-top:1rem;">
          <img src="/images/logo-ufop.png" alt="UFOP" style="height:36px;opacity:0.7;"
               onerror="this.style.display='none'" />
        </div>
      </div>
      <div class="footer-col">
        <h4>{{ data.footer.nav_heading }}</h4>
        <ul>
          <li><a href="{{ base_url }}" class="d2c_footer_link">{{ data.nav.home }}</a></li>
          <li><a href="{{ base_url }}#pesquisa" class="d2c_footer_link">{{ data.nav.research }}</a></li>
          <li><a href="{{ base_url }}/equipe" class="d2c_footer_link">{{ data.nav.team }}</a></li>
          <li><a href="{{ base_url }}/publicacoes" class="d2c_footer_link">{{ data.nav.publications }}</a></li>
          <li><a href="{{ base_url }}#consultorias" class="d2c_footer_link">{{ data.nav.consulting }}</a></li>
          <li><a href="{{ base_url }}#noticias" class="d2c_footer_link">{{ data.nav.news }}</a></li>
          <li><a href="{{ base_url }}/contato" class="d2c_footer_link">{{ data.nav.contact_btn }}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>{{ data.footer.team_heading }}</h4>
        <ul>
          {% for link in data.footer.team_links %}
          <li><a href="{{ base_url }}/equipe{{ link.anchor }}" class="d2c_footer_link">{{ link.text }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="footer-col">
        <h4>{{ data.footer.social_heading }}</h4>
        <ul>
          {% for s in data.footer.social_links %}
          <li><a href="{{ s.href }}" target="_blank" class="d2c_footer_link">{{ s.text }}</a></li>
          {% endfor %}
        </ul>
        <div class="social-links" style="margin-top:1.25rem;">
          <a href="https://twitter.com/CSILab_UFOP" target="_blank" class="d2c_social_link" title="Twitter">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.instagram.com/csilab_ufop/" target="_blank" class="d2c_social_link" title="Instagram">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://github.com/ufopcsilab" target="_blank" class="d2c_social_link" title="GitHub">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>
    </div>
    {% endblock %}
    <div class="footer-bottom">
      <p>{{ data.footer.copyright }}</p>
      <div class="footer-bottom-links">
        {% for link in data.footer.bottom_links %}
        <a href="{{ link.href }}"{% if link.external %} target="_blank"{% endif %}>{{ link.text }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
