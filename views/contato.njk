{% from "_macros.njk" import icon %}
{% extends "base.njk" %}

{% block head %}
<style>
  @media (max-width:768px) { .how-to-join-grid { grid-template-columns:1fr !important; } }
</style>
{% endblock %}

{% block content %}

<section style="padding-top:8rem;padding-bottom:2rem;">
  <div class="container">
    <span class="section-label">{{ page.page_label }}</span>
    <h1 class="d2c_title" style="margin-top:0.75rem;margin-bottom:1rem;">{{ page.page_title }}</h1>
    <p class="text-lavender" style="font-size:1rem;max-width:560px;line-height:1.75;">{{ page.page_sub }}</p>
  </div>
</section>

<section style="padding-top:1rem;padding-bottom:6rem;">
  <div class="container">
    <div class="contact-grid" data-aos="fade-up">

      <form class="contact-form" id="contact-form" novalidate>
        <input type="text" class="form-control" placeholder="{{ page.form_name }}" required />
        <div class="form-row">
          <input type="tel" class="form-control" placeholder="{{ page.form_phone }}" />
          <input type="email" class="form-control" placeholder="{{ page.form_email }}" required />
        </div>
        <input type="text" class="form-control" placeholder="{{ page.form_subject }}" />
        <textarea class="form-control" rows="6" placeholder="{{ page.form_message }}" required></textarea>
        <button type="submit" class="btn-primary" style="align-self:flex-start;"
                data-sending="{{ page.form_sending }}"
                data-sent="{{ page.form_sent }}"
                data-default="{{ page.form_submit }}">{{ page.form_submit }}</button>
      </form>

      <div class="contact-info-card" data-aos="fade-left">
        <h3>{{ data.contact.info_title }}</h3>

        {% for c in data.contact.contacts %}
        <div class="contact-detail">
          <div class="contact-detail-icon">{{ icon("mail", 20) }}</div>
          <div class="contact-detail-text">
            <strong>{{ c.email }}</strong>
            <p>{{ c.person }}</p>
          </div>
        </div>
        {% endfor %}

        <div class="contact-detail">
          <div class="contact-detail-icon">{{ icon("location", 20) }}</div>
          <div class="contact-detail-text">
            <strong>{{ data.contact.location.room }}</strong>
            <p>{{ data.contact.location.dept }}<br/>{{ data.contact.location.univ }}</p>
          </div>
        </div>

        <div class="contact-detail">
          <div class="contact-detail-icon">{{ icon("building", 20) }}</div>
          <div class="contact-detail-text">
            <strong><a href="https://ufop.br" target="_blank" style="color:var(--color-text);">ufop.br</a></strong>
            <p><a href="http://www3.decom.ufop.br/decom/inicio/" target="_blank" style="color:var(--color-muted);">decom.ufop.br</a></p>
          </div>
        </div>

        <div class="contact-detail">
          <div class="contact-detail-icon">{{ icon("web", 20) }}</div>
          <div class="contact-detail-text">
            <strong><a href="https://csilab.ufop.br" target="_blank" style="color:var(--color-accent);">{{ data.contact.website_official }}</a></strong>
            <p>{{ data.contact.website_official_label }}</p>
          </div>
        </div>

        <div class="social-links" style="margin-top:1.5rem;">
          <a href="https://twitter.com/CSILab_UFOP" target="_blank" class="d2c_social_link" title="@CSILab_UFOP">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.instagram.com/csilab_ufop/" target="_blank" class="d2c_social_link" title="@csilab_ufop">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://github.com/ufopcsilab" target="_blank" class="d2c_social_link" title="ufopcsilab">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div data-aos="fade-up" data-aos-delay="150" style="margin-top:3rem;background:var(--color-surface);border:1px solid rgba(255,255,255,0.07);border-left:4px solid var(--color-accent);border-radius:12px;padding:2rem 2.5rem;">
      <h3 style="font-size:1.15rem;margin-bottom:1rem;color:var(--color-text);">{{ data.contact.join_title }}</h3>
      <div class="how-to-join-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">
        {% for item in data.contact.join_items %}
        <div>
          <div style="margin-bottom:0.75rem;">{{ icon(item.icon, 26, "var(--color-accent)", "2") }}</div>
          <strong style="color:var(--color-text);font-size:0.95rem;">{{ item.title }}</strong>
          <p class="text-lavender" style="font-size:0.875rem;margin-top:0.4rem;line-height:1.6;">{{ item.text }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% endblock %}
